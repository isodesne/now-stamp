	"description": "Inline timestamps for Obsidian whose day label stays alive — Today, Yesterday, weekday, date.",
	"main": "main.js",
	"author": "isodesne",
	"repository": {
		"type": "git",
		"url": "https://github.com/isodesne/dynamic-stamp.git"
	},
